# --- Quai RPC ---
# Single zone JSON-RPC endpoint. Handles all RPC methods plus live mining/supply
# via `quai_getMiningInfo`, so no separate gateway endpoint is required.
#
# Options (path-based, zone-suffixed):
#   - https://debug.rpc.quai.network/cyprus1  (has PR 2696: historical getMiningInfo)
#   - https://rpc.quai.network/cyprus1         (stable public gateway, current-tip only)
#
# For a local dev node, use the bare port (e.g. http://10.0.0.12:9200).
# When unset, defaults to `https://rpc.quai.network/${NEXT_PUBLIC_QUAI_ZONE}`.
QUAI_ZONE_RPC=https://debug.rpc.quai.network/cyprus1

NEXT_PUBLIC_QUAI_ZONE=cyprus1

# Enables the /history chart grid. When false, /history shows a placeholder card
# instead of fetching rollups. Flip to "true" once /api/rollups is healthy.
NEXT_PUBLIC_ROLLUPS_ENABLED=true

# --- Postgres ---
# Connection URL for the emissions Postgres. Used by migrations, the ingest
# worker, and the Next.js app. For production, point at a managed Postgres
# (Supabase/Neon/RDS) and include ?sslmode=require.
DATABASE_URL=postgresql://user:CHANGE_ME@host:5432/quaiemissions?sslmode=require
